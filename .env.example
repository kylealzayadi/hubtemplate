# Copy to .env.local and fill in your own values.
# .env.local is git-ignored — never commit it.

# Lock screen password (client-side gate — not real auth, anyone with
# devtools can bypass it; just keeps the page private from a glance).
VITE_LOCK_PASSWORD=changeme

# Optional: gates the "Tools" tab with a second password.
VITE_TOOLS_PASSWORD=changeme

# GitHub username for the Projects tab (shows your public repos + recent
# commits). Leave blank to disable.
VITE_GITHUB_USERNAME=

# Optional: name + a few profile links for the hero row. JSON-encoded.
# Example:
# VITE_PROFILE='{"name":"Your Name","links":[{"label":"site","url":"https://example.com"}]}'
VITE_PROFILE=
