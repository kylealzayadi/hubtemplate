# Copy this file to .env.local and fill in your own values.
# The .env.local file is git-ignored — never commit real secrets.

# Shared secret used by the client (Vite) and the Cloudflare Worker.
# Generate one with: openssl rand -hex 32
# Set the same value in Cloudflare Pages → Settings → Environment variables
# as API_KEY (no VITE_ prefix) so the Worker can verify requests.
VITE_API_KEY=change-me

# Lock screen password (client-side gate — not a real auth boundary).
VITE_LOCK_PASSWORD=changeme

# Optional: gates the "Tools" tab with a second password.
VITE_TOOLS_PASSWORD=changeme

# GitHub username to fetch repos / contribution heatmap for.
# Leave blank to disable the GitHub widgets.
VITE_GITHUB_USERNAME=

# Optional: name + a few profile links shown in the hero row. JSON-encoded.
# Example:
# VITE_PROFILE='{"name":"Your Name","links":[{"label":"site","url":"https://example.com"}]}'
VITE_PROFILE=
