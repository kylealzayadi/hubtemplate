{
  "name": "the-hub",
  "version": "1.0.0",
  "description": "The Hub — a personal command-center framework. Fork it, fill it in.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2025-01-01 --d1=DB=hub-db",
    "db:create": "wrangler d1 create hub-db",
    "db:init": "wrangler d1 execute hub-db --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute hub-db --local --file=./schema.sql",
    "db:query": "wrangler d1 execute hub-db --remote --command",
    "db:dump": "wrangler d1 execute hub-db --remote --command \"SELECT * FROM log_entries ORDER BY log_type, date DESC, item_id;\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
